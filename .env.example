# Provenance Guard — environment template.
# Copy to `.env` (which is git-ignored) and fill in your real values.
#
# A free Groq API key is available at https://console.groq.com/keys
# Without a live key the pipeline still runs end-to-end via a deterministic
# fallback signal (see README → "Running without a Groq key").

GROQ_API_KEY=

# Optional overrides (sensible defaults baked into config.py):
# GROQ_MODEL=llama-3.3-70b-versatile
# PROVENANCE_DB=provenance_guard.db

# HMAC secret for signing "Verified Human" certificates (stretch feature).
# REQUIRED in production — set a long random string (e.g. `python -c "import
# secrets; print(secrets.token_hex(32))"`). If unset, a random per-process secret
# is generated and certificates will not survive a restart.
# PROVENANCE_CERT_SECRET=
